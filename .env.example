# ---------------------------------------------------------------------------
# LLM config for the playwright-planner / -generator / -healer sub-agents.
# ---------------------------------------------------------------------------
#
# The agents talk to any OpenAI-compatible endpoint (litellm proxy, OpenAI,
# Anthropic via litellm, Together, Groq, OpenRouter, local Ollama with
# `litellm --model ollama/...`, etc.).
#
# Examples:
#
#   # litellm proxy (recommended)
#   LITELLM_BASE_URL=http://localhost:4000/v1
#   LITELLM_MODEL=anthropic/claude-sonnet-4-5
#   LITELLM_API_KEY=sk-litellm-master-key
#
#   # direct OpenAI
#   LITELLM_BASE_URL=https://api.openai.com/v1
#   LITELLM_MODEL=gpt-4o
#   LITELLM_API_KEY=sk-...
#
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MODEL=anthropic/claude-sonnet-4-5
LITELLM_API_KEY=sk-placeholder
LITELLM_TEMPERATURE=0
LITELLM_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Runtime paths. Override when running outside a Hyperswitch dashboard repo.
# ---------------------------------------------------------------------------
# Backend (Hyperswitch Rust stack) — used by setupBackend.
HYPERSWITCH_HEALTH_URL=http://localhost:8080/health
HYPERSWITCH_START_SCRIPT=playwright-tests/start_hyperswitch.sh
HYPERSWITCH_STOP_CWD=hyperswitch
BACKEND_START_TIMEOUT_MS=240000
BACKEND_POLL_STEP_MS=5000

# Frontend (Node.js dashboard) — used by setupFrontend.
FRONTEND_URL=http://localhost:9000
FRONTEND_PORT=9000
FRONTEND_BUILD_CMD=npm run re:start
FRONTEND_START_CMD=npm run start
FRONTEND_START_TIMEOUT_MS=240000
FRONTEND_POLL_STEP_MS=5000

# Paths used by the generator / healer.
GENERATED_TESTS_DIR=playwright-tests/ai-generated
EXISTING_TESTS_DIR=playwright-tests/e2e
PAGE_OBJECTS_DIR=playwright-tests/support/pages
PLAYWRIGHT_PASSWORD=Test@123456

# Set to "1" to enable real browser exploration inside planner/generator/healer.
# Disable if Playwright isn't installed or no browser is reachable.
ENABLE_BROWSER_TOOLS=1
